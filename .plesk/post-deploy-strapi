#!/bin/bash
# ============================================================================
# Plesk Git Post-Deploy Script — Strapi CMS API (strapi-api branch)
# ============================================================================
# Runs after Plesk Git deploys the strapi-api branch to your API subdomain.
# This script installs Node.js dependencies, builds Strapi, and configures
# the environment for production.
#
# Plesk Git Setup:
#   Domain:     api-oc.yourdomain.com  (or api.yourdomain.com)
#   Branch:     strapi-api
#   Deploy To:  /var/www/vhosts/api-oc.yourdomain.com/httpdocs/
#   Action:     bash .plesk/post-deploy-strapi
# ============================================================================

set -e

# Plesk deploy shell has a restricted PATH — ensure common binaries are found
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:$PATH"

# ── Colours ────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# ── Paths ──────────────────────────────────────────────────────────────────
DEPLOY_DIR="$PWD"
LOG_FILE="/tmp/plesk-strapi-deploy.log"

log() { echo "[DEPLOY] $(date '+%H:%M:%S')  $1" | tee -a "$LOG_FILE"; }
ok()  { echo -e "  ${GREEN}✓${NC} $1"; }
warn(){ echo -e "  ${YELLOW}⚠${NC} $1"; }
err() { echo -e "  ${RED}✗${NC} $1"; exit 1; }

# ── Detect Plesk owner ─────────────────────────────────────────────────────
detect_owner() {
    PLESK_OWNER=$(stat -c '%U' "$DEPLOY_DIR" 2>/dev/null || echo "")
    PLESK_GROUP="psacln"
    if [ -z "$PLESK_OWNER" ] || [ "$PLESK_OWNER" = "root" ]; then
        PLESK_OWNER=$(ls -ld /var/www/vhosts/ 2>/dev/null | head -1 | awk '{print $3}')
    fi
    log "Plesk owner: ${PLESK_OWNER:-unknown}"
}

# ── Check Node.js ──────────────────────────────────────────────────────────
check_node() {
    log "Checking Node.js..."

    if ! command -v node &>/dev/null; then
        err "Node.js not found. Install it via Plesk → Updates → Add/Remove Components → Node.js"
    fi

    NODE_VERSION=$(node -v 2>/dev/null | cut -d'v' -f2 | cut -d'.' -f1)
    NPM_VERSION=$(npm -v 2>/dev/null || echo "unknown")

    log "Node.js $(node -v)  |  npm v$NPM_VERSION"

    if [ -n "$NODE_VERSION" ] && [ "$NODE_VERSION" -lt 18 ]; then
        err "Node.js $NODE_VERSION is too old. Strapi 5 requires Node.js 18+"
    fi

    ok "Node.js version OK"
}

# ── Check for package.json ─────────────────────────────────────────────────
check_package() {
    if [ ! -f "$DEPLOY_DIR/package.json" ]; then
        err "package.json not found — is this the strapi-api branch?"
    fi
    ok "package.json found"
}

# ── Install / update npm dependencies ──────────────────────────────────────
install_deps() {
    log "Installing Node.js dependencies..."

    cd "$DEPLOY_DIR"

    # Use ci for reproducible builds when lockfile exists, otherwise install
    if [ -f "package-lock.json" ]; then
        npm ci --prefer-offline --no-audit 2>&1 | tail -8
    else
        npm install --prefer-offline --no-audit 2>&1 | tail -8
    fi

    ok "Dependencies installed"
}

# ── Create .env if missing ─────────────────────────────────────────────────
setup_env() {
    log "Setting up environment..."

    cd "$DEPLOY_DIR"

    if [ ! -f ".env" ]; then
        if [ -f ".env.example" ]; then
            cp .env.example .env

            # Auto-generate secure secrets
            if command -v openssl &>/dev/null; then
                APP_KEYS=$(for i in 1 2 3 4; do openssl rand -hex 16; done | paste -sd,)
                API_TOKEN_SALT=$(openssl rand -hex 16)
                ADMIN_JWT_SECRET=$(openssl rand -hex 16)
                TRANSFER_TOKEN_SALT=$(openssl rand -hex 16)
                JWT_SECRET=$(openssl rand -hex 16)

                sed -i "s/APP_KEYS=.*/APP_KEYS=$APP_KEYS/" .env
                sed -i "s/API_TOKEN_SALT=.*/API_TOKEN_SALT=$API_TOKEN_SALT/" .env
                sed -i "s/ADMIN_JWT_SECRET=.*/ADMIN_JWT_SECRET=$ADMIN_JWT_SECRET/" .env
                sed -i "s/TRANSFER_TOKEN_SALT=.*/TRANSFER_TOKEN_SALT=$TRANSFER_TOKEN_SALT/" .env
                sed -i "s/JWT_SECRET=.*/JWT_SECRET=$JWT_SECRET/" .env
                ok "Generated secure secrets"
            else
                warn "openssl not available — using example secrets (CHANGE THESE!)"
            fi

            ok ".env created from .env.example"
        else
            warn "No .env.example found — Strapi will use defaults"
        fi
    else
        ok ".env already exists"
    fi
}

# ── Build Strapi admin panel ───────────────────────────────────────────────
build_strapi() {
    log "Building Strapi admin panel..."

    cd "$DEPLOY_DIR"
    NODE_ENV=production npm run build 2>&1 | tail -10

    ok "Strapi build complete"
}

# ── Fix Plesk permissions ──────────────────────────────────────────────────
fix_permissions() {
    log "Fixing file permissions for Plesk..."

    if [ -n "$PLESK_OWNER" ] && [ "$PLESK_OWNER" != "root" ]; then
        chown -R "$PLESK_OWNER:$PLESK_GROUP" "$DEPLOY_DIR" 2>/dev/null || true

        # Ensure writable dirs
        for dir in "$DEPLOY_DIR/.cache" "$DEPLOY_DIR/.tmp" "$DEPLOY_DIR/dist" "$DEPLOY_DIR/public/uploads" "$DEPLOY_DIR/build"; do
            if [ -d "$dir" ]; then
                chmod -R 775 "$dir" 2>/dev/null || true
            fi
        done

        ok "Permissions fixed"
    else
        warn "Could not determine Plesk owner — skipping permission fix"
    fi
}

# ── Restart Strapi process (if running via PM2) ────────────────────────────
restart_strapi() {
    log "Checking for PM2 process manager..."

    if command -v pm2 &>/dev/null; then
        local app_name="strapi-oc-api"
        if pm2 list 2>/dev/null | grep -q "$app_name"; then
            pm2 restart "$app_name" 2>&1 | tail -3
            ok "Strapi restarted via PM2"
        else
            warn "PM2 found but no '$app_name' process — start manually with: pm2 start npm --name '$app_name' -- start"
        fi
    else
        warn "PM2 not installed — start Strapi manually:"
        warn "  cd $DEPLOY_DIR && nohup npm start > /tmp/strapi-run.log 2>&1 &"
        warn "  Or install PM2: npm install -g pm2 && pm2 start npm --name 'strapi-oc-api' -- start"
    fi
}

# ── Main ───────────────────────────────────────────────────────────────────
main() {
    echo ""
    echo -e "${CYAN}╔══════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║   Strapi CMS API — Plesk Deploy              ║${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════╝${NC}"
    echo ""

    log "Starting Strapi API deployment..."
    log "Deploy directory: $DEPLOY_DIR"

    detect_owner
    check_node
    check_package
    install_deps
    setup_env
    build_strapi
    fix_permissions
    restart_strapi

    echo ""
    echo -e "${GREEN}╔══════════════════════════════════════════════╗${NC}"
    echo -e "${GREEN}║   Strapi API Deploy Complete!                ║${NC}"
    echo -e "${GREEN}╚══════════════════════════════════════════════╝${NC}"
    echo ""
    log "Next steps:"
    log "  1. Edit .env with your database credentials"
    log "  2. Start Strapi: cd $DEPLOY_DIR && npm start"
    log "  3. Create admin user at: https://your-api-domain.com/admin"
    log "  4. Seed demo data: curl -X POST https://your-api-domain.com/api/seed"
    log ""
    log "Log file: $LOG_FILE"
}

main
