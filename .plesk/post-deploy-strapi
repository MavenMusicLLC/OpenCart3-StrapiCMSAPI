#!/bin/bash
# Plesk Git Post-Deploy Script — Strapi CMS API
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/opt:/opt/plesk/php/8.2/bin:/opt/plesk/php/8.2/sbin:$HOME/bin:$PATH"

log() { echo "[$1] $2"; }
ok()  { echo "OK: $1"; }
warn(){ echo "WARN: $1"; }
err() { echo "ERROR: $1"; exit 1; }

log "INFO" "Starting Strapi deployment"
log "INFO" "PATH=$PATH"

ok "Deployment complete"
