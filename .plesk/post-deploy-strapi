#!/bin/bash
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:$PATH"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DEPLOY_DIR="$(dirname "$SCRIPT_DIR")"

echo "[deploy] Strapi deployment"
echo "[deploy] Directory: $DEPLOY_DIR"

cd "$DEPLOY_DIR" || { echo "[deploy] Error: Cannot cd to $DEPLOY_DIR"; exit 1; }

if [ -f "package.json" ]; then
    echo "[deploy] npm install..."
    /usr/bin/npm install --no-audit --no-fund 2>&1 | tail -2
    echo "[deploy] npm build..."
    /usr/bin/npm run build 2>&1 | tail -2
fi

echo "[deploy] Setting permissions..."
find . -type d -exec chmod 755 {} \; 2>/dev/null || true

echo "[deploy] Starting PM2..."
/usr/bin/pm2 delete strapi 2>/dev/null || true
/usr/bin/pm2 start package.json --name strapi -- start 2>&1 | tail -3
/usr/bin/pm2 save 2>/dev/null || true

echo "[deploy] Complete"
