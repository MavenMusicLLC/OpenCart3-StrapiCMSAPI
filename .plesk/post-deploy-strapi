#!/bin/bash
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/opt/plesk/php/8.2/bin:$HOME/bin:$PATH"
DEPLOY_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$DEPLOY_DIR"
echo "[deploy] Starting..."
if [ -f "package.json" ]; then
    echo "[deploy] npm install..."
    /usr/bin/npm install --no-audit --no-fund
    echo "[deploy] npm build..."
    /usr/bin/npm run build
    echo "[deploy] Done"
fi
