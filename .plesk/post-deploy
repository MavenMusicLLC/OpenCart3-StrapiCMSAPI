#!/bin/bash
# ============================================================================
# Plesk Git Post-Deploy Script for Strapi API
# ============================================================================
# This runs after Git deploys the strapi-api branch to Plesk
# Designed to work in Plesk's chrooted environment
# ============================================================================

set -e

DEPLOY_DIR="$PWD"
LOG_FILE="/tmp/plesk-strapi-deploy.log"

log() {
    echo "[DEPLOY] $1" | tee -a "$LOG_FILE" 2>/dev/null || echo "[DEPLOY] $1"
}

# Check if Node.js is available
check_node() {
    if ! command -v node &> /dev/null; then
        log "ERROR: Node.js not found. Please install Node.js 18+ via Plesk Node.js extension"
        exit 1
    fi
    
    NODE_VERSION=$(node -v 2>/dev/null | cut -d'v' -f2 | cut -d'.' -f1)
    if [ -n "$NODE_VERSION" ] && [ "$NODE_VERSION" -lt "18" ]; then
        log "WARNING: Node.js $NODE_VERSION found, but 18+ recommended"
    fi
    
    log "Node.js version: $(node -v 2>/dev/null || echo 'unknown')"
}

# Install dependencies
install_deps() {
    log "Installing Node.js dependencies..."
    cd "$DEPLOY_DIR"
    
    if [ ! -f "package.json" ]; then
        log "ERROR: package.json not found"
        exit 1
    fi
    
    npm install 2>&1 | tail -5
    log "Dependencies installed"
}

# Build Strapi
build_strapi() {
    log "Building Strapi..."
    cd "$DEPLOY_DIR"
    
    if [ ! -f ".env" ]; then
        if [ -f ".env.example" ]; then
            log "Creating .env from example..."
            cp .env.example .env
            log "WARNING: Please edit .env with your database credentials"
        else
            log "ERROR: No .env or .env.example found"
            exit 1
        fi
    fi
    
    npm run build 2>&1 | tail -10
    log "Strapi built successfully"
}

# Fix permissions
fix_permissions() {
    local plesk_user=$(ls -ld "$DEPLOY_DIR" 2>/dev/null | awk '{print $3}')
    
    if [ -n "$plesk_user" ] && [ "$plesk_user" != "root" ]; then
        chown -R "$plesk_user:psacln" "$DEPLOY_DIR/node_modules" 2>/dev/null || true
        chown -R "$plesk_user:psacln" "$DEPLOY_DIR/.cache" 2>/dev/null || true
        chown -R "$plesk_user:psacln" "$DEPLOY_DIR/dist" 2>/dev/null || true
        chown -R "$plesk_user:psacln" "$DEPLOY_DIR/.tmp" 2>/dev/null || true
        chown -R "$plesk_user:psacln" "$DEPLOY_DIR/public" 2>/dev/null || true
        log "Permissions fixed"
    fi
}

# Main
main() {
    log "Starting Strapi API deployment..."
    check_node
    install_deps
    build_strapi
    fix_permissions
    log "Deployment complete!"
    log "Next steps:"
    log "  1. Edit .env with your database credentials"
    log "  2. Run: npm start"
    log "  3. Access admin at: https://yourdomain.com/admin"
    log "Log file: $LOG_FILE"
}

main