#!/bin/bash
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:$PATH"

SCRIPT_DIR="$(cd "$(dirname "$0")" 2>/dev/null && pwd)"
DEPLOY_DIR="$SCRIPT_DIR"
if [ -z "$DEPLOY_DIR" ] || [ ! -d "$DEPLOY_DIR" ]; then
    DEPLOY_DIR="$(dirname "$(pwd)")"
fi

echo "[deploy] OpenCart module deployment"
echo "[deploy] Working dir: $(pwd)"
echo "[deploy] Script dir: $SCRIPT_DIR"

if [ -f "index.php" ]; then
    echo "[deploy] OpenCart installation detected"
elif [ -f "../index.php" ]; then
    cd ..
    echo "[deploy] OpenCart found in parent dir"
else
    echo "[deploy] OpenCart files in current directory"
fi

echo "[deploy] Done"
