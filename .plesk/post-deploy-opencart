#!/bin/bash
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:$PATH"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DEPLOY_DIR="$(dirname "$SCRIPT_DIR")"

echo "[deploy] OpenCart module deployment"
echo "[deploy] Script dir: $SCRIPT_DIR"
echo "[deploy] Deploy dir: $DEPLOY_DIR"

cd "$DEPLOY_DIR" || { echo "[deploy] Error: Cannot cd to $DEPLOY_DIR"; exit 1; }

if [ -f "index.php" ]; then
    echo "[deploy] OpenCart installation detected"
else
    echo "[deploy] Warning: index.php not found in $DEPLOY_DIR"
fi

echo "[deploy] Done"
