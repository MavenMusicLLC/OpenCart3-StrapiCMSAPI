#!/bin/bash
# ============================================================================
# Plesk Git Post-Deploy Script — OpenCart Module (main branch)
# ============================================================================
# Runs after Plesk Git deploys the main branch to your OpenCart store root.
# This script installs the OpenCart Bundle module files and runs migrations.
#
# Plesk Git Setup:
#   Domain:     oc.yourdomain.com
#   Branch:     main
#   Deploy To:  /var/www/vhosts/yourdomain.com/httpdocs/
#   Action:     bash .plesk/post-deploy-opencart
# ============================================================================

set -e

# ── Colours ────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# ── Paths ──────────────────────────────────────────────────────────────────
DEPLOY_DIR="$PWD"
LOG_FILE="/tmp/plesk-opencart-deploy.log"
MODULE_DIR="$DEPLOY_DIR/opencart-module"

log() { echo "[DEPLOY] $(date '+%H:%M:%S')  $1" | tee -a "$LOG_FILE"; }
ok()  { echo -e "  ${GREEN}✓${NC} $1"; }
warn(){ echo -e "  ${YELLOW}⚠${NC} $1"; }
err() { echo -e "  ${RED}✗${NC} $1"; exit 1; }

# ── Detect Plesk owner ─────────────────────────────────────────────────────
detect_owner() {
    PLESK_OWNER=$(stat -c '%U' "$DEPLOY_DIR" 2>/dev/null || echo "")
    PLESK_GROUP="psacln"
    if [ -z "$PLESK_OWNER" ] || [ "$PLESK_OWNER" = "root" ]; then
        PLESK_OWNER=$(ls -ld /var/www/vhosts/ 2>/dev/null | head -1 | awk '{print $3}')
    fi
    log "Plesk owner: ${PLESK_OWNER:-unknown}"
}

# ── Check this is an OpenCart installation ─────────────────────────────────
check_opencart() {
    log "Verifying OpenCart installation..."
    if [ ! -f "$DEPLOY_DIR/index.php" ]; then
        warn "index.php not found — this may not be an OpenCart root"
        warn "If this is a fresh deploy, upload OpenCart files first"
        return 1
    fi
    if [ ! -f "$DEPLOY_DIR/config.php" ]; then
        warn "config.php not found — OpenCart may not be installed yet"
        return 1
    fi
    ok "OpenCart installation detected"
    return 0
}

# ── Copy module files ──────────────────────────────────────────────────────
install_module_files() {
    log "Installing OpenCart Bundle module files..."

    if [ ! -d "$MODULE_DIR" ]; then
        err "opencart-module/ directory not found in repository"
    fi

    # Catalog (frontend)
    if [ -d "$MODULE_DIR/catalog" ]; then
        cp -r "$MODULE_DIR/catalog/"* "$DEPLOY_DIR/catalog/" 2>/dev/null || true
        ok "Catalog files copied"
    fi

    # Admin
    if [ -d "$MODULE_DIR/admin" ]; then
        cp -r "$MODULE_DIR/admin/"* "$DEPLOY_DIR/admin/" 2>/dev/null || true
        ok "Admin files copied"
    fi

    # Install scripts
    if [ -d "$MODULE_DIR/install" ]; then
        mkdir -p "$DEPLOY_DIR/install"
        cp -r "$MODULE_DIR/install/"* "$DEPLOY_DIR/install/" 2>/dev/null || true
        ok "Install scripts copied"
    fi
}

# ── Run database migration ─────────────────────────────────────────────────
run_migration() {
    log "Running database migration..."

    if [ -f "$DEPLOY_DIR/install/migrate.php" ]; then
        if php "$DEPLOY_DIR/install/migrate.php" 2>&1 | tail -5; then
            ok "Database migration complete"
        else
            warn "Migration script ran with warnings — check logs"
        fi
    elif [ -f "$DEPLOY_DIR/install/bundle_install.sql" ]; then
        DB_NAME=$(php -r "include '$DEPLOY_DIR/config.php'; echo DB_DATABASE;" 2>/dev/null || echo "")
        DB_USER=$(php -r "include '$DEPLOY_DIR/config.php'; echo DB_USERNAME;" 2>/dev/null || echo "")
        DB_PASS=$(php -r "include '$DEPLOY_DIR/config.php'; echo DB_PASSWORD;" 2>/dev/null || echo "")
        if [ -n "$DB_NAME" ] && [ -n "$DB_USER" ]; then
            mysql -u "$DB_USER" -p"$DB_PASS" "$DB_NAME" < "$DEPLOY_DIR/install/bundle_install.sql" 2>/dev/null && \
                ok "SQL migration applied" || warn "SQL migration failed — DB may already be up to date"
        fi
    else
        warn "No migration script found — skipping"
    fi
}

# ── Clear OpenCart cache ───────────────────────────────────────────────────
clear_cache() {
    log "Clearing OpenCart cache..."
    local cache_dir="$DEPLOY_DIR/system/storage/cache"
    local mod_dir="$DEPLOY_DIR/system/storage/modification"

    if [ -d "$cache_dir" ]; then
        rm -rf "$cache_dir"/* 2>/dev/null || true
        ok "Cache cleared"
    fi
    if [ -d "$mod_dir" ]; then
        rm -rf "$mod_dir"/* 2>/dev/null || true
        ok "Modification cache cleared"
    fi
}

# ── Fix Plesk permissions ──────────────────────────────────────────────────
fix_permissions() {
    log "Fixing file permissions for Plesk..."

    if [ -n "$PLESK_OWNER" ] && [ "$PLESK_OWNER" != "root" ]; then
        # Module directories
        for dir in \
            "$DEPLOY_DIR/catalog/controller/module" \
            "$DEPLOY_DIR/catalog/model/module" \
            "$DEPLOY_DIR/catalog/view/theme/default/template/module" \
            "$DEPLOY_DIR/catalog/view/theme/default/template/extension/module" \
            "$DEPLOY_DIR/catalog/language/en-gb/module" \
            "$DEPLOY_DIR/catalog/language/en-gb/extension/module" \
            "$DEPLOY_DIR/admin/controller/module" \
            "$DEPLOY_DIR/admin/model/module" \
            "$DEPLOY_DIR/admin/view/module" \
            "$DEPLOY_DIR/admin/language/en-gb/module"; do
            if [ -d "$dir" ]; then
                chown -R "$PLESK_OWNER:$PLESK_GROUP" "$dir" 2>/dev/null || true
            fi
        done

        # Set 755 for directories, 644 for files
        find "$DEPLOY_DIR/catalog" -type d -exec chmod 755 {} \; 2>/dev/null || true
        find "$DEPLOY_DIR/catalog" -type f -exec chmod 644 {} \; 2>/dev/null || true
        find "$DEPLOY_DIR/admin" -type d -exec chmod 755 {} \; 2>/dev/null || true
        find "$DEPLOY_DIR/admin" -type f -exec chmod 644 {} \; 2>/dev/null || true

        ok "Permissions fixed"
    else
        warn "Could not determine Plesk owner — skipping permission fix"
    fi
}

# ── Update STRAPI_API_URL in config ────────────────────────────────────────
update_config() {
    log "Checking Strapi API configuration..."
    local domain=$(echo "$DEPLOY_DIR" | grep -oP 'vhosts/\K[^/]+')
    local api_url="https://api-${domain}/api"

    # Only add if not already present
    if ! grep -q "STRAPI_API_URL" "$DEPLOY_DIR/config.php" 2>/dev/null; then
        echo "" >> "$DEPLOY_DIR/config.php"
        echo "// Bundle Manager — Strapi API Integration" >> "$DEPLOY_DIR/config.php"
        echo "define('STRAPI_API_URL', '$api_url');" >> "$DEPLOY_DIR/config.php"
        ok "STRAPI_API_URL set to $api_url"
    else
        ok "STRAPI_API_URL already configured"
    fi
}

# ── Main ───────────────────────────────────────────────────────────────────
main() {
    echo ""
    echo -e "${CYAN}╔══════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║   OpenCart Bundle Module — Plesk Deploy      ║${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════╝${NC}"
    echo ""

    log "Starting OpenCart module deployment..."
    log "Deploy directory: $DEPLOY_DIR"

    detect_owner

    if check_opencart; then
        install_module_files
        run_migration
        update_config
        clear_cache
        fix_permissions
    else
        warn "OpenCart not fully installed — only module files were placed"
        install_module_files
        fix_permissions
    fi

    echo ""
    echo -e "${GREEN}╔══════════════════════════════════════════════╗${NC}"
    echo -e "${GREEN}║   OpenCart Module Deploy Complete!           ║${NC}"
    echo -e "${GREEN}╚══════════════════════════════════════════════╝${NC}"
    echo ""
    log "Next steps:"
    log "  1. Go to OpenCart Admin → Extensions → Modules"
    log "  2. Install 'Bundle Manager'"
    log "  3. Configure API URL if using Strapi"
    log ""
    log "Log file: $LOG_FILE"
}

main
