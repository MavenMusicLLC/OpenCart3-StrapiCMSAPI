#!/bin/bash
# Plesk Git Post-Deploy Script — OpenCart Module
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/opt:/opt/plesk/php/8.2/bin:/opt/plesk/php/8.2/sbin:$HOME/bin:$PATH"

log() { echo "LOG: $1"; }
ok()  { echo "OK: $1"; }
warn(){ echo "WARN: $1"; }

log "Starting OpenCart module deployment"

if /usr/bin/test -f "index.php"; then
    ok "OpenCart installation found"
else
    warn "OpenCart index.php not found"
fi

ok "Deployment complete"
