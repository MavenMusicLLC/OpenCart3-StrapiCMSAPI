# ============================================================================
# Strapi .env — Example Production Configuration
# For: OpenCart3-StrapiCMSAPI on Plesk Obsidian
# ============================================================================
# COPY THIS FILE TO .env AND FILL IN YOUR ACTUAL VALUES
# DO NOT commit actual credentials to version control!
# ============================================================================

HOST=0.0.0.0
PORT=1337

# ── Secrets (generate new values!) ─────────────────────────────────────────
# Generate with: openssl rand -hex 16
# Or: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
APP_KEYS=YOUR_SECRET_KEY_1,YOUR_SECRET_KEY_2,YOUR_SECRET_KEY_3,YOUR_SECRET_KEY_4
API_TOKEN_SALT=YOUR_API_TOKEN_SALT
ADMIN_JWT_SECRET=YOUR_ADMIN_JWT_SECRET
TRANSFER_TOKEN_SALT=YOUR_TRANSFER_TOKEN_SALT
JWT_SECRET=YOUR_JWT_SECRET

# ── Database (fill in your actual credentials) ──────────────────────────────
DATABASE_CLIENT=mysql
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=strapi_opencart
DATABASE_USERNAME=strapi_user
DATABASE_PASSWORD=YOUR_STRONG_PASSWORD_HERE
DATABASE_SSL=false
DATABASE_FILENAME=.tmpdata.db

# ── Optional ────────────────────────────────────────────────────────────────
# STRAPI_TELEMETRY_DISABLED=true
# PUBLIC_URL=https://api.yourdomain.com